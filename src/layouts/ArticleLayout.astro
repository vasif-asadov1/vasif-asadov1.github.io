---
import MainLayout from './MainLayout.astro';
import ProjectNavigation from '../components/ProjectNavigation.astro';
import '../styles/global.css';

// 1. next ve prev proplarını içeri alıyoruz (artık [...slug].astro'dan geliyor)
const { frontmatter, headings, currentId, collectionName, next, prev } = Astro.props;

// 2. Frontmatter'dan gelen gizleme komutları
const hideNext = frontmatter.hide_next === true || frontmatter.hide_next === 'true';
const hidePrev = frontmatter.hide_prev === true || frontmatter.hide_prev === 'true';

// 3. SENIOR DOKUNUŞU: Otomatik ve Manuel Link Hesaplama
// Eğer markdown'da custom URL verdiysen onu kullanır, yoksa otomatik sıradaki dosyayı bulur
const finalPrevUrl = frontmatter.custom_prev_url || (prev && prev.id !== 'index' ? `/${collectionName.replace('_', '-')}/${prev.id}` : null);
const finalPrevTitle = frontmatter.custom_prev_title || (prev ? prev.data.title : null);

const finalNextUrl = frontmatter.custom_next_url || (next && next.id !== 'index' ? `/${collectionName.replace('_', '-')}/${next.id}` : null);
const finalNextTitle = frontmatter.custom_next_title || (next ? next.data.title : null);
---

<MainLayout title={frontmatter.title}>
  <div class="flex flex-col lg:flex-row gap-12">
    
    <article class="w-full lg:w-3/4 prose prose-invert max-w-none">
      <header class="mb-10">
        <h1 class="text-4xl font-extrabold mb-4">{frontmatter.title}</h1>
        {frontmatter.description && <p class="text-xl text-gray-500">{frontmatter.description}</p>}
        <div class="flex flex-wrap gap-2 mt-4">
          {frontmatter.tags?.map((tag: string) => (
            <span class="px-3 py-1 bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 rounded-full text-xs font-semibold">
              #{tag}
            </span>
          ))}
        </div>
      </header>
      
      {currentId && collectionName && !currentId.endsWith('index') && (
        <ProjectNavigation currentId={currentId} collectionName={collectionName} />
      )}

      <slot />

      <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center not-prose">
        
        <div class="w-1/2 pr-4">
          {/* Eğer gizlenmemişse VE gidecek bir URL varsa Previous butonunu göster */}
          {!hidePrev && finalPrevUrl && (
            <a 
              href={finalPrevUrl} 
              class="group flex flex-col items-start text-slate-500 hover:text-teal-400 transition-colors"
            >
              <span class="text-xs font-bold uppercase tracking-wider mb-1">← Previous</span>
              <span class="text-sm lg:text-base font-semibold text-slate-700 dark:text-slate-300 group-hover:text-teal-400 transition-colors line-clamp-2">
                {finalPrevTitle}
              </span>
            </a>
          )}
        </div>

        <div class="w-1/2 pl-4 text-right">
          {/* Eğer gizlenmemişse VE gidecek bir URL varsa Next butonunu göster */}
          {!hideNext && finalNextUrl && (
            <a 
              href={finalNextUrl} 
              class="group flex flex-col items-end text-slate-500 hover:text-[#c084fc] transition-colors"
            >
              <span class="text-xs font-bold uppercase tracking-wider mb-1">Next →</span>
              <span class="text-sm lg:text-base font-semibold text-slate-700 dark:text-slate-300 group-hover:text-[#c084fc] transition-colors line-clamp-2">
                {finalNextTitle}
              </span>
            </a>
          )}
        </div>
        
      </div>
      </article>

    <aside class="hidden xl:block w-72 shrink-0">
      <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto toc-scrollbar pr-4">
        <h3 class="font-bold text-xs uppercase tracking-widest text-slate-500 mb-6">On This Page</h3>
        
        <ul class="space-y-3 text-sm text-slate-400">
          {headings.map((heading) => (
            <li>
              <a 
                href={`#${heading.slug}`} 
                class="toc-link block border-l-2 border-transparent hover:text-teal-400 transition-all duration-200"
                style={`padding-left: ${(heading.depth - 2) * 1 + 0.75}rem;`}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

  </div>
</MainLayout>

<script>
  const codeBlocks = document.querySelectorAll('pre');

  codeBlocks.forEach((block) => {
    const button = document.createElement('button');
    
    // Efsanevi "Pro" CSS sınıfları (İkon tabanlı, blur efektli, zarif)
    button.className = 'absolute right-3 top-3 p-2 rounded-lg bg-slate-800/80 text-slate-400 hover:text-teal-400 hover:bg-slate-700/90 border border-slate-700/50 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 flex items-center gap-1.5';
    
    // Kopyalama İkonu (SVG)
    const copyIcon = `<svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>`;
    
    // Onay (Check) İkonu (SVG)
    const checkIcon = `<svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-teal-400"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`;

    // Başlangıçta sadece kopyalama ikonunu göster
    button.innerHTML = copyIcon;
    
    block.classList.add('group');
    block.appendChild(button);

    button.addEventListener('click', async () => {
      const code = block.querySelector('code');
      if (code) {
        await navigator.clipboard.writeText(code.innerText);
        
        // Tıklanınca yeşil neon glow (parlama) efekti, onay ikonu ve zarif bir yazı
        button.innerHTML = checkIcon + '<span class="text-xs font-bold text-teal-400 font-sans tracking-wide">Copied</span>';
        button.classList.add('border-teal-500/50', 'bg-teal-500/10');
        button.classList.remove('text-slate-400');
        
        // 2 saniye sonra sessizce eski asil haline dön
        setTimeout(() => {
          button.innerHTML = copyIcon;
          button.classList.remove('border-teal-500/50', 'bg-teal-500/10');
          button.classList.add('text-slate-400');
        }, 2000);
      }
    });
  });
</script>



<script>
  function setupTOC() {
    const tocLinks = document.querySelectorAll('.toc-link');
    // H2, H3 ve H4 başlıklarını kapsama alıyoruz
    const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3, .prose h4'));

    if (headings.length === 0 || tocLinks.length === 0) return;

    // Önce hepsini sıfırla
    tocLinks.forEach(link => {
      link.classList.remove('text-teal-400', 'font-bold', 'border-teal-500');
      link.classList.add('border-transparent');
    });

    const observerOptions = {
      root: null,
      // Aktif alanı ekranın tam ortasına odaklıyoruz
      rootMargin: '-15% 0px -75% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          if (!id) return;

          tocLinks.forEach((link) => {
            if (link.getAttribute('href') === `#${id}`) {
              // Diğerlerini temizle
              tocLinks.forEach(l => {
                l.classList.remove('text-teal-400', 'font-bold', 'border-teal-500');
                l.classList.add('border-transparent');
              });
              // Aktif olanı yak
              link.classList.remove('border-transparent');
              link.classList.add('text-teal-400', 'font-bold', 'border-teal-500');
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach((heading) => observer.observe(heading));
  }

  // Astro sayfa geçişleri ve ilk yükleme için çift dikiş
  document.addEventListener('astro:page-load', () => {
    setTimeout(setupTOC, 100); // DOM'un yerleşmesi için 100ms bekle
  });

  // Eğer sayfa ilk defa yükleniyorsa
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupTOC);
  } else {
    setupTOC();
  }
</script>
