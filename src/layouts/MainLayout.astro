---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import CyberBackground from '../components/CyberBackground.astro'; 
import BackToTop from '../components/BackToTop.astro'; 

// FRONTMATTER ALANI (Server-side JavaScript/TypeScript)
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
{/* TÜM SİTEYİ KALICI OLARAK KARANLIK MODA KİLİTLİYORUZ */}
<html lang="en" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title} | Data Science & AI Research</title>

        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
          integrity="sha384-n8MVd4RsNIU0tAv4ctWMnEYPzhcH8DnSVRqWVZiALPu5W38J8lxhz3at6WPLOc7v"
          crossorigin="anonymous"
        />
        
    </head>
    
    <body class="bg-gradient-to-br from-[#1e212b] to-[#14161c] text-slate-200 min-h-screen flex flex-col antialiased selection:bg-teal-500 selection:text-white">
        
        {/* 3. YAĞMURUN HİÇ KESİLMEMESİ İÇİN 'transition:persist' EKLİYORUZ */}
        <div transition:persist="cyber-background">
            <CyberBackground />
        </div>
        
        <BackToTop /> {/* REAKTÖR BURADA ÇALIŞIYOR */}
        
        <Navbar />
        
        {/* NEON İLERLEME ÇUBUĞU (KORUNDU) */}
        <div id="progress-container" class="fixed top-[64px] left-0 w-full h-[3px] z-50 bg-transparent">
            <div id="progress-bar" class="h-full bg-gradient-to-r from-teal-400 via-cyan-400 to-purple-500 w-0 transition-all duration-150 ease-out"></div>
        </div>

        {/* İçeriğin yağmurun üstünde kalmasını garantilemek için relative ve z-10 ekledik */}
        <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 relative z-10">
            <slot />
        </main>

        {/* İLERLEME ÇUBUĞU SCRİPTİ (KORUNDU VE BODY İÇİNE ALINDI) */}
        <script>
            // Kaydırma olayını dinleyen ultra hafif script
            function updateProgressBar() {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                // Eğer sayfa kaydırılamıyorsa (içerik kısaysa) çubuğu gizle
                if (height <= 0) return; 
                
                const scrolled = (winScroll / height) * 100;
                const progressBar = document.getElementById("progress-bar");
                if (progressBar) {
                progressBar.style.width = scrolled + "%";
                }
            }

            // Sayfa kaydırıldıkça barı güncelle
            window.addEventListener("scroll", updateProgressBar);
            
            // Sayfa ilk yüklendiğinde ve Astro sayfa geçişlerinde (ViewTransitions) çalışması için
            document.addEventListener("astro:page-load", updateProgressBar);
            document.addEventListener("DOMContentLoaded", updateProgressBar);
        </script>
    </body>
</html>