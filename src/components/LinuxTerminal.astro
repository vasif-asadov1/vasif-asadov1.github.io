---
// src/components/LinuxTerminal.astro
// Eğer title girilmezse varsayılan olarak bu efsanevi prompt görünür.
const { title = "vasif@cachyos: ~" } = Astro.props;
---

<div class="my-8 rounded-lg overflow-hidden border border-slate-700/80 shadow-2xl bg-[#0f172a]">
  
  {/* KDE Plasma / Alacritty Tarzı Linux Başlık Çubuğu */}
  <div class="flex items-center justify-between px-4 py-2 bg-slate-800 border-b border-slate-700/50 select-none">
    
    {/* Sol Kısım: Terminal İkonu ve Başlık */}
    <div class="flex items-center gap-3">
      <svg class="w-4 h-4 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M4 15a1 1 0 001 1h14a1 1 0 001-1V9a1 1 0 00-1-1H5a1 1 0 00-1 1v6z" />
      </svg>
      <span class="font-mono text-sm font-bold text-slate-300">{title}</span>
    </div>
    
    {/* Sağ Kısım: Klasik Linux Pencere Kontrolleri (_, □, ×) */}
    <div class="flex items-center gap-4 text-slate-400 font-sans text-lg leading-none">
      <span class="cursor-default hover:text-white transition-colors mt-[-8px]">_</span>
      <span class="cursor-default hover:text-white transition-colors text-sm">□</span>
      <span class="cursor-default hover:text-red-500 transition-colors text-xl">×</span>
    </div>

  </div>
  
  {/* Terminal İçeriği (MDX'ten Gelen Kodlar) */}
  <div class="linux-terminal-body p-2">
    <slot />
  </div>

</div>

<style is:global>
  /* İçeri giren varsayılan Markdown kod bloğunun kenarlıklarını sıfırlıyoruz ki terminalle bütünleşsin */
  .linux-terminal-body pre {
    margin: 0 !important;
    border-radius: 0 0 0.5rem 0.5rem !important;
    background-color: transparent !important;
    border: none !important;
  }
</style>