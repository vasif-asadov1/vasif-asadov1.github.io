---
// src/components/ProImage.astro
const { src, alt = "Project Image", caption, width, height } = Astro.props;

const customStyle = [
  width && `width: ${width}`,
  height && `height: ${height}`
].filter(Boolean).join('; ');
---

{/* Astro'nun Client-Side scriptleri izole etmek için kullandığı Web Component sarıcısı */}
<pro-image data-src={src}>
  <figure class="pro-figure group relative m-0 my-10 overflow-hidden rounded-xl border border-slate-700/50 bg-slate-800/20 shadow-lg cursor-zoom-in">
    
    {/* Üzerine gelince beliren şık büyüteç ikonu */}
    <div class="absolute inset-0 z-10 flex items-center justify-center bg-slate-900/40 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 group-hover:opacity-100 pointer-events-none">
      <div class="rounded-full bg-slate-800/80 p-3 text-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.5)] border border-teal-500/30">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
      </div>
    </div>

    <img 
      class="main-img w-full h-auto object-contain transition-transform duration-500 group-hover:scale-[1.02]"
      src={src} 
      alt={alt} 
      loading="lazy" 
      style={customStyle || null}
    />
    
    {caption && (
      <figcaption class="bg-slate-800/80 px-4 py-3 text-center text-sm text-slate-300 border-t border-slate-700/50" set:html={caption} />
    )}
  </figure>

  {/* SİNEMATİK LIGHTBOX (Gizli Başlar) */}
  <div class="lightbox fixed inset-0 z-[100] hidden h-screen w-screen bg-slate-950/95 backdrop-blur-xl select-none">
    
    {/* Üst Kontrol Paneli */}
    <div class="absolute top-0 left-0 w-full p-4 flex justify-between items-center z-50 bg-gradient-to-b from-slate-900/80 to-transparent">
      
      {/* Sol taraf: Zoom Bilgisi ve İpuçları */}
      <div class="flex items-center gap-3 text-slate-400 text-xs font-mono ml-2">
        <span class="zoom-level text-teal-400 font-bold bg-teal-500/10 px-2 py-1 rounded border border-teal-500/20">100%</span>
        <span class="hidden md:inline">Scroll to zoom • Drag to pan</span>
      </div>

      {/* Sağ taraf: Aksiyon Butonları (Copy, Download, Close) */}
      <div class="flex gap-3">
        {/* Copy Button */}
        <button class="lb-copy group flex items-center justify-center p-2.5 rounded-lg bg-slate-800/80 text-slate-300 border border-slate-600/50 hover:border-teal-500/50 hover:text-teal-400 hover:bg-slate-700 transition-all shadow-lg" title="Copy Image">
          <svg class="copy-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          <svg class="check-icon w-5 h-5 hidden text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
        </button>

        {/* Download Button */}
        <button class="lb-download flex items-center justify-center p-2.5 rounded-lg bg-slate-800/80 text-slate-300 border border-slate-600/50 hover:border-cyan-500/50 hover:text-cyan-400 hover:bg-slate-700 transition-all shadow-lg" title="Download Image">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        </button>

        {/* Close Button */}
        <button class="lb-close flex items-center justify-center p-2.5 rounded-lg bg-slate-800/80 text-rose-400 border border-slate-600/50 hover:border-rose-500/50 hover:text-rose-300 hover:bg-rose-900/30 transition-all shadow-lg ml-2" title="Close (Esc)">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </div>

    {/* Resim Alanı (Pan ve Zoom buraya uygulanır) */}
    <div class="lb-canvas absolute inset-0 flex items-center justify-center overflow-hidden cursor-grab active:cursor-grabbing">
      <img src={src} alt={alt} class="lb-img max-w-[90vw] max-h-[90vh] object-contain transition-transform duration-75 ease-out will-change-transform" />
    </div>
  </div>
</pro-image>

<script>
  // Web Component Tanımlaması (Her resim için izole çalışır, birbirine karışmaz)
  class ProImage extends HTMLElement {
    constructor() {
      super();

      // HTML Elementlerini Yakalama
      const mainImg = this.querySelector('.main-img');
      const lightbox = this.querySelector('.lightbox');
      const lbImg = this.querySelector('.lb-img');
      const lbCanvas = this.querySelector('.lb-canvas');
      const closeBtn = this.querySelector('.lb-close');
      const downloadBtn = this.querySelector('.lb-download');
      const copyBtn = this.querySelector('.lb-copy');
      const copyIcon = this.querySelector('.copy-icon');
      const checkIcon = this.querySelector('.check-icon');
      const zoomText = this.querySelector('.zoom-level');
      const imgSrc = this.dataset.src;

      // Zoom ve Pan Değişkenleri
      let scale = 1;
      let isDragging = false;
      let startX = 0, startY = 0;
      let translateX = 0, translateY = 0;

      // --- 1. LIGHTBOX AÇMA & KAPATMA ---
      const openLightbox = () => {
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Arka plan kaydırmasını kilitle
        resetTransform();
      };

      const closeLightbox = () => {
        lightbox.classList.add('hidden');
        document.body.style.overflow = ''; // Kilidi aç
      };

      mainImg.addEventListener('click', openLightbox);
      closeBtn.addEventListener('click', closeLightbox);
      
      // Boşluğa tıklayınca da kapansın
      lightbox.addEventListener('click', (e) => {
        if (e.target === lbCanvas || e.target === lightbox) closeLightbox();
      });

      // ESC tuşu ile kapatma
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
      });

      // --- 2. TEKERLEK İLE YAKINLAŞTIRMA (SCROLL ZOOM) ---
      const updateTransform = () => {
        lbImg.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
        zoomText.innerText = `${Math.round(scale * 100)}%`;
      };

      const resetTransform = () => {
        scale = 1; translateX = 0; translateY = 0;
        updateTransform();
      };

      lbCanvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        // Scroll yönüne göre zoom in/out
        const zoomAmount = e.deltaY * -0.002;
        scale += zoomAmount;
        // Limitler (Maksimum %500 zoom, Minimum %50)
        scale = Math.min(Math.max(0.5, scale), 5);
        updateTransform();
      });

      // --- 3. FARE İLE SÜRÜKLEME (PAN / DRAG) ---
      lbCanvas.addEventListener('mousedown', (e) => {
        isDragging = true;
        startX = e.clientX - translateX;
        startY = e.clientY - translateY;
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging || lightbox.classList.contains('hidden')) return;
        translateX = e.clientX - startX;
        translateY = e.clientY - startY;
        updateTransform();
      });

      window.addEventListener('mouseup', () => isDragging = false);

      // --- 4. İNDİRME BUTONU (DOWNLOAD) ---
      downloadBtn.addEventListener('click', () => {
        const link = document.createElement('a');
        link.href = imgSrc;
        // Dosya ismini URL'den çıkart veya varsayılan isim ver
        link.download = imgSrc.split('/').pop() || 'vasif_asadov_data_science_image.png';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });

      // --- 5. KOPYALAMA BUTONU (COPY TO CLIPBOARD) ---
      copyBtn.addEventListener('click', async () => {
        try {
          // Resmi blob (veri bloğu) olarak çekip panoya yazıyoruz
          const response = await fetch(imgSrc);
          const blob = await response.blob();
          await navigator.clipboard.write([
            new ClipboardItem({ [blob.type]: blob })
          ]);

          // Başarılı olursa ikonları değiştir ve glow efekti ver
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          copyBtn.classList.replace('border-slate-600/50', 'border-teal-500/50');
          copyBtn.classList.add('bg-teal-500/10');

          // 2 Saniye sonra eski haline döndür
          setTimeout(() => {
            checkIcon.classList.add('hidden');
            copyIcon.classList.remove('hidden');
            copyBtn.classList.replace('border-teal-500/50', 'border-slate-600/50');
            copyBtn.classList.remove('bg-teal-500/10');
          }, 2000);

        } catch (error) {
          console.error('Kopyalama başarısız:', error);
          alert('Resim kopyalanamadı. Tarayıcı izinlerini kontrol edin.');
        }
      });
    }
  }

  // Eğer daha önce tanımlanmadıysa componenti sisteme tanıt
  if (!customElements.get('pro-image')) {
    customElements.define('pro-image', ProImage);
  }
</script>